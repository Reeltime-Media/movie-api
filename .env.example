# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Movies API
DEBUG=false
# Comma-separated frontend origins (Next.js may use 3001 if 3000 is taken)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# IPv4 pooler — required for Alembic from macOS and for Docker (Session or Transaction mode)
POOLER_DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:password@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=movies
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ── Baray Payment Gateway ─────────────────────────────────────────────────────
BARAY_API_KEY=your-baray-api-key
BARAY_WEBHOOK_SECRET=your-baray-webhook-secret
BARAY_BASE_URL=https://api.baray.io
