# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Movies API
DEBUG=false
# Comma-separated frontend origins (Next.js may use 3001 if 3000 is taken)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Public client URL for payment success redirects (optional; CORS_ORIGINS also allowed)
APP_PUBLIC_URL=http://localhost:3000

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# IPv4 pooler — required for Alembic from macOS and for Docker (Session or Transaction mode)
# Session mode (port 5432). Port 6543 is transaction mode and breaks asyncpg SSL handshakes.
POOLER_DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:password@aws-0-REGION.pooler.supabase.com:5432/postgres
# Transcode worker only — docker-compose maps this to DATABASE_URL in that container.
# Not loaded by the main API Settings class; set POOLER_DATABASE_URL above for the API.
# TRANSCODE_DATABASE_URL=postgresql+asyncpg://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Object layout (keys stored in DB; public URL = R2_PUBLIC_URL + key):
#   movies/{slug}/source.mp4 | poster.{ext} | hls/master.m3u8
#   series/{series_slug}/poster.{ext}
#   series/{series_slug}/episodes/{episode_slug}/source.mp4 | poster.{ext} | hls/…
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=movies
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ── Baray Payment Gateway ─────────────────────────────────────────────────────
BARAY_API_KEY=your-baray-api-key
BARAY_SK=your-baray-sk-base64
BARAY_IV=your-baray-iv-base64
BARAY_WEBHOOK_SECRET=your-baray-webhook-secret
BARAY_BASE_URL=https://api.baray.io
BARAY_CHECKOUT_BASE_URL=https://pay.baray.io
API_PUBLIC_URL=http://localhost:8000

# Transcode worker (admin API proxy — key never sent to browsers)
TRANSCODE_SERVICE_URL=http://localhost:8001
TRANSCODE_API_KEY=your-transcode-api-key

# ── Resend (transactional email — password reset) ────────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Reeltime <onboarding@resend.dev>
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
